# Backend Environment Configuration

## Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axiom_dev

## Redis
REDIS_URL=redis://localhost:6379

## JWT Authentication
JWT_SECRET=your-secret-key-min-32-chars-long-for-security

## Auth0 (Optional)
AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

## Server
PORT=3000
NODE_ENV=development

## Socket.io / WebSocket
CLIENT_URL=http://localhost:3001,http://localhost:3002,http://localhost:3000

## API Settings
API_VERSION=v1
LOG_LEVEL=info

## Payments (Mocked for MVP)
YAPE_API_KEY=yape-api-key-here
YAPE_API_SECRET=yape-api-secret-here
PLIN_API_KEY=plin-api-key-here
STRIPE_SECRET_KEY=sk_test_...

## AWS S3 (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=axiom-dev

## Monitoring (Optional)
DATADOG_API_KEY=your-datadog-key
SENTRY_DSN=your-sentry-dsn
