# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axiom_dev
MONGODB_URL=mongodb://localhost:27017/axiom_dev
REDIS_URL=redis://localhost:6379

# CouchDB (Sync Server)
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# Auth
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
JWT_SECRET=your-secret-key-min-32-chars-long

# AWS
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=axiom-dev

# APIs & External Services
MAPBOX_TOKEN=
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# Payment Integration
YAPE_API_KEY=
PLIN_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ML Services
ML_SERVICE_URL=http://localhost:5000
FRAUD_DETECTION_MODEL_ID=fraud-v1
DEMAND_PREDICTION_MODEL_ID=demand-v1

# Firebase
FIREBASE_PROJECT_ID=axiom-peru
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Admin Dashboard
ADMIN_SECRET=your-admin-secret-key

# Environment
NODE_ENV=development
LOG_LEVEL=debug
